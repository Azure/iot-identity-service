#!/usr/bin/make -f

# See debhelper(7)

# output every command that modifies files on the build system.
export DH_VERBOSE = 1
export DH_OPTIONS = -v


PRIVATE_LIBS = /usr/lib/aziot-identity-service

%:
	dh $@

.PHONY: override_dh_auto_build override_dh_auto_install override_dh_auto_test override_dh_clean override_dh_installsystemd override_dh_shlibdeps

override_dh_auto_build:
	# Default behavior is `make -j1`, which is not quite right for us.
	make -j \
		RELEASE=1 \
		V=1

override_dh_auto_install:
	# Default behavior is `make -j1 install DESTDIR=$$PWD/debian/aziot-identity-service`, which is not quite right for us.
	case "$$ARCH" in \
		'amd64') arch_libdir='x86_64-linux-gnu';; \
		'arm32v7') arch_libdir='arm-linux-gnueabihf';; \
		'aarch64') arch_libdir='aarch64-linux-gnu';; \
		'*') exit 1;; \
	esac; \
	case "$$(openssl version)" in \
	    'OpenSSL 3.'*) engines_dir="/usr/lib/$$arch_libdir/engines-3";; \
	    'OpenSSL 1.1.'*) engines_dir="/usr/lib/$$arch_libdir/engines-1.1";; \
		'*') exit 1;; \
	esac; \
	make -j \
		DESTDIR="$$PWD/debian/aziot-identity-service" \
		localstatedir=/var \
		sysconfdir=/etc \
		unitdir=/lib/systemd/system \
		OPENSSL_ENGINES_DIR="$$engines_dir" \
		RELEASE=1 \
		V=1 \
		install-deb

# Default behavior of dh_installsystemd is to enable and start all installed units, ie both sockets and services.
# But we don't want to enable or start the services, since the sockets will start them automatically anyway.
override_dh_installsystemd:
	dh_installsystemd aziot-certd.socket aziot-identityd.socket aziot-keyd.socket aziot-tpmd.socket
	dh_installsystemd --no-enable --no-start aziot-certd.service aziot-identityd.service aziot-keyd.service aziot-tpmd.service

override_dh_auto_test:
	# Default behavior is `make test`, which we don't need, and won't work for cross-compiled packages anyway.
	echo 'noop'

# `dh_clean` deletes all `*.orig` by default, which then makes cargo complain since it expects the `Cargo.toml.orig` of vendored crates to be present.
#
# Ref: https://salsa.debian.org/mozilla-team/firefox/-/commit/36feb8449706f4d06b18759954b16c382e26ec6e
override_dh_clean:
	dh_clean --exclude=Cargo.toml.orig

override_dh_shlibdeps:
	dh_shlibdeps -l /usr/lib/aziot-identity-service
